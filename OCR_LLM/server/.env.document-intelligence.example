# -----------------------------------------------------------------------------
# Merge these into OCR_LLM/server/.env (or .env.development) to align AnythingLLM
# with document-intelligence stack (BGE-M3 + Qwen family).
# See: OCR_LLM/services/document-intelligence/INTEGRATION_PDF_PROCESSING_UI.md
# -----------------------------------------------------------------------------

# --- Embedding: same model family as chatbot / Chroma (BGE-M3) ---
# 1) Start: OCR_LLM\python_embedding\start-bge-embed.bat
#    (or uvicorn tools.bge_m3_embedding_server:app --port 8010)
EMBEDDING_ENGINE=generic-openai
EMBEDDING_BASE_PATH=http://127.0.0.1:8010/v1
EMBEDDING_MODEL_PREF=BAAI/bge-m3
GENERIC_OPEN_AI_EMBEDDING_API_KEY=not-used
# Optional if many chunks:
# GENERIC_OPEN_AI_EMBEDDING_API_DELAY_MS=200

# --- Chat LLM: Qwen via Ollama (closest practical match to local Qwen3-4B stack) ---
# Pull model first: ollama pull qwen3:8b
LLM_PROVIDER=ollama
OLLAMA_BASE_PATH=http://127.0.0.1:11434
OLLAMA_MODEL_PREF=qwen3:8b
OLLAMA_MODEL_TOKEN_LIMIT=16384
OLLAMA_PREDICT_TOKENS=8192

# --- Alternative embedding without local server (needs API key) ---
# EMBEDDING_ENGINE=openrouter
# EMBEDDING_MODEL_PREF=baai/bge-m3
# OPENROUTER_API_KEY=
