# Placeholder .env file for collector runtime

# This enables HTTP request/response logging in development. Set value to truthy string to enable, leave empty value or comment out to disable
# ENABLE_HTTP_LOGGER=""
# This enables timestamps for the HTTP Logger. Set value to true to enable, leave empty or comment out to disable
# ENABLE_HTTP_LOGGER_TIMESTAMPS=""

# PDF OCR fallback (for scanned or mixed PDFs without a text layer)
# Truthy values: 1, true, yes, on
# COLLECTOR_ENABLE_PDF_OCR_FALLBACK="true"
# COLLECTOR_PDF_OCR_LANGS="eng"
# COLLECTOR_PDF_OCR_MAX_EXECUTION_TIME_MS="300000"
# COLLECTOR_PDF_OCR_BATCH_SIZE="10"
# COLLECTOR_PDF_OCR_MAX_WORKERS="4"

# Optional: send PDFs to the PDF extract bridge first (advanced PDF/scan pipeline).
# Start from repo: cd services/pdf_processing && python -m uvicorn api.extract_main:app --host 0.0.0.0 --port 8001
# Or from repo root: scripts\startup\start-pdf-extract-bridge.bat
# If unset or request fails, Collector falls back to the built-in PDF loader + OCR.
# PDF_PROCESSING_EXTRACT_URL=http://127.0.0.1:8001/integrations/chatbot-extract-pdf
# PDF_PROCESSING_EXTRACT_TOKEN=
# PDF_PROCESSING_EXTRACT_FIRST=true
# PDF_PROCESSING_EXTRACT_TIMEOUT_MS=900000
# PDF_PROCESSING_EXTRACT_RETRIES=5
# PDF_PROCESSING_EXTRACT_RETRY_DELAY_MS=3000
# If true: when bridge fails, do NOT fall back to local PDF.js/Tesseract.
# PDF_PROCESSING_EXTRACT_REQUIRE_BRIDGE="true"